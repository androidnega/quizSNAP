# =============================================================================
# QuizSnap — PRODUCTION ENVIRONMENT ONLY
# =============================================================================
# Server: Ubuntu 24.04 | 48 GB RAM | 12 CPU | PHP 8.4 | Nginx | MySQL 8 | Redis
#
# RESOURCE BUDGET (48 GB / 12 CPU) — do NOT tune beyond these reservations:
#   OS + infrastructure:  4 CPU |  4 GB RAM
#   Redis:                —   |  4 GB RAM  (maxmemory 3gb in redis-production.conf)
#   MySQL:                —   |  8 GB RAM  (buffer pool 6G in mysql-production.cnf)
#   Netdata/Nginx/Super:  —   |  2 GB RAM
#   QuizSnap app only:    8 CPU | 24 GB RAM (PHP-FPM + queue + Reverb)
#
# Target: 2,500 concurrent students — stability and headroom over max throughput.
# Post-deploy: run ./production-audit.sh, then fill production-audit-report.txt
#
# DEPLOYMENT (does NOT affect local development):
#   1. Copy to server:  cp .env.production /var/www/quizsnap/.env
#   2. Generate key:   php artisan key:generate
#   3. Fill secrets below (DB password, REVERB keys, API keys)
#
# LOCAL DEVELOPMENT: keep using your existing .env (file cache, file sessions).
# =============================================================================

APP_NAME=QuizSnap
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://quizsnap.example.com
APP_TIMEZONE=UTC

LOG_CHANNEL=daily
LOG_LEVEL=warning
LOG_DAILY_DAYS=14
LOG_DEPRECATIONS_CHANNEL=null
LOG_DEPRECATIONS_TRACE=false

# ── Database (MySQL 8) ───────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=quizsnap_production
DB_USERNAME=quizsnap_app
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ── Redis — sessions, cache, queues (all three) ──────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_PREFIX=quizsnap_prod_
REDIS_PERSISTENT=true

CACHE_STORE=redis
CACHE_PREFIX=quizsnap_prod_cache_

SESSION_DRIVER=redis
SESSION_CONNECTION=default
SESSION_LIFETIME=480
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

QUEUE_CONNECTION=redis
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=120

# Failed jobs (keep in MySQL for audit)
QUEUE_FAILED_DRIVER=database-uuids

# ── Broadcasting / Laravel Reverb (live dashboard + proctor) ─────────────────
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=quizsnap-prod
REVERB_APP_KEY=CHANGE_ME_32_CHAR_RANDOM_KEY
REVERB_APP_SECRET=CHANGE_ME_64_CHAR_RANDOM_SECRET
REVERB_HOST=quizsnap.example.com
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
REVERB_SCALING_ENABLED=true

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ── QuizSnap high-concurrency tuning ─────────────────────────────────────────
QUIZ_DEFER_HEARTBEAT_WRITES=true
QUIZ_HEARTBEAT_FLUSH_SECONDS=45
QUIZ_PROCTOR_BROADCAST_THROTTLE=3
QUIZ_QUESTION_POOL_CACHE_SECONDS=120

# ── Files ────────────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local

# ── Mail (production SMTP) ───────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@quizsnap.example.com
MAIL_FROM_NAME="${APP_NAME}"

# ── AI / SMS (set in Admin → Settings or here) ─────────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
ARKESEL_API_KEY=

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: php artisan key:generate (APP_KEY)
# Never commit real secrets to git.

# ── Optional: Horizon (only if you install laravel/horizon) ─────────────────
# HORIZON_PREFIX=quizsnap_horizon:
