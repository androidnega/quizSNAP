APP_NAME=QuizSnap
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.example

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=quizsnap
DB_USERNAME=quizsnap
DB_PASSWORD=

# ── Redis (required for 1000+ concurrent quiz takers) ─────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_CONNECTION=default
QUEUE_CONNECTION=redis

# ── Live WebSocket (Laravel Reverb) ───────────────────────────────────────
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=quizsnap
REVERB_APP_KEY=change-me-long-random-key
REVERB_APP_SECRET=change-me-long-random-secret
REVERB_HOST=your-domain.example
REVERB_PORT=8080
REVERB_SCHEME=https
REVERB_SCALING_ENABLED=true

# Vite / frontend reads these for student + dashboard sockets
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ── Quiz scale tuning ─────────────────────────────────────────────────────
QUIZ_DEFER_HEARTBEAT_WRITES=true
QUIZ_HEARTBEAT_FLUSH_SECONDS=45
QUIZ_PROCTOR_BROADCAST_THROTTLE=3

FILESYSTEM_DISK=local

OPENAI_API_KEY=
GEMINI_API_KEY=

# Cron (every minute): php /var/www/quizsnap/artisan schedule:run
